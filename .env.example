# ========== AI 配置 ==========
# Provider: mock（默认；无需密钥即可完整体验）或 openai-compatible。
# 请勿在此文件或 Git 仓库中填写真实密钥。
AI_PROVIDER=mock
# OpenAI-compatible API 地址，例如 https://api.openai.com/v1
AI_BASE_URL=
# API Key（仅服务端使用，绝不暴露到前端）
AI_API_KEY=
# 模型名，例如 gpt-4o-mini
AI_MODEL=
# 请求超时（毫秒）
AI_TIMEOUT=60000

# ========== 本地 SQLite 开发 ==========
# 默认 Prisma schema：prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# ========== Neon PostgreSQL / Vercel 生产环境 ==========
# Vercel 运行时使用 Neon pooled URL；迁移使用 Neon direct URL。
# 部署时请覆盖上面的 DATABASE_URL，并同时设置 DIRECT_URL。
# DATABASE_URL="postgresql://USER:PASSWORD@EP-...-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@EP-....REGION.aws.neon.tech/neondb?sslmode=require"

# ========== 认证 ==========
# 生成方式：openssl rand -base64 32
AUTH_SECRET=

# ========== 站点 ==========
NEXT_PUBLIC_APP_URL=http://localhost:3000
